{
  "name": "tamv-md-x4-knowledge-cells",
  "version": "1.0.0",
  "description": "Hyper-specialized microservice architecture for 3D/4D rendering, quantum integrations, and immersive AI effects",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.ts\"",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "orchestrate": "node src/orchestrator/ai-orchestrator.ts"
  },
  "keywords": [
    "3D-rendering",
    "4D-visualization",
    "quantum-computing",
    "immersive-AI",
    "microservices",
    "XR",
    "WebGL",
    "multisensory"
  ],
  "author": "TAMV MD-X4 Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.0",
    "prom-client": "^15.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^9.32.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
