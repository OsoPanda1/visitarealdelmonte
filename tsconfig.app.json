{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": ["./src/*"],
      "@geo-engine": ["./packages/geo-engine/src/index.ts"],
      "@geo-engine/*": ["./packages/geo-engine/src/*"],
      "@core-kernel": ["./packages/core-kernel/src/index.ts"],
      "@core-kernel/*": ["./packages/core-kernel/src/*"],
      "@data-models": ["./packages/data-models/src/index.ts"],
      "@data-models/*": ["./packages/data-models/src/*"],
      "@ui-kit": ["./packages/ui-kit/src/index.ts"],
      "@ui-kit/*": ["./packages/ui-kit/src/*"],
      "@ai-core": ["./services/ai-core/src/index.ts"],
      "@ai-core/*": ["./services/ai-core/src/*"],
      "@twin": ["./services/territorial-twin/src/index.ts"],
      "@twin/*": ["./services/territorial-twin/src/*"],
      "@economy": ["./services/economy/src/index.ts"],
      "@economy/*": ["./services/economy/src/*"],
      "@analytics": ["./services/analytics/src/index.ts"],
      "@analytics/*": ["./services/analytics/src/*"],
      "@culture": ["./services/culture/src/index.ts"],
      "@culture/*": ["./services/culture/src/*"],
      "@app-web/*": ["./apps/web/src/*"],
      "@app-admin/*": ["./apps/admin/src/*"]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "types": [
      "vitest/globals"
    ],
    "useDefineForClassFields": true
  },
  "include": [
    "src",
    "packages/*/src",
    "services/*/src",
    "apps/*/src"
  ]
}