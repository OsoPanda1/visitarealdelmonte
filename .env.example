# ──────────────────────────────────────────────
# RDM Digital Hub — Variables de Entorno
# ──────────────────────────────────────────────
# Copia este archivo como .env y completa los valores.
# Todas las variables VITE_* son públicas (van al bundle del frontend).
# Variables sin VITE_ son solo para entornos servidor/Edge Functions.

# === Supabase (requerido para auth + base de datos) ===
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Sentry (opcional — monitoreo de errores) ===
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxx.ingest.sentry.io/xxxxxx

# === PostHog (opcional — analytics de producto) ===
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com

# === Entorno (development | preview | production | test) ===
# Se usa para controlar sample rates de Sentry, flags de features, etc.
VITE_APP_ENV=development

# === Vercel AI Gateway (primary — Claude vía suscripción, sin costo por token) ===
# 1. Crea un gateway en https://vercel.com → AI Gateway
# 2. Configura tu API key de Anthropic (Claude) en el dashboard
# 3. Copia la URL del gateway (ej: https://gateway.ai.vercel.com/v1/{projectId}/{gatewayId})
# 4. Genera un token de acceso en Vercel → Settings → Tokens
# VERCEL_AI_GATEWAY_URL=https://gateway.ai.vercel.com/v1/project_abc/gateway_def
# VERCEL_AI_GATEWAY_TOKEN=vercel_token_xxx
# VERCEL_AI_GATEWAY_MODEL=claude-sonnet-4-20250514

# === Gemini / Fallback AI (server-side, sin prefijo VITE_) ===
# Solo se usa si VERCEL_AI_GATEWAY_URL no está configurado o falla.
# GEMINI_API_KEY=AIza...

# === Model Router / Open Science AI (server-side, sin prefijo VITE_) ===
# MODEL_ROUTER_URL apunta a tu Vercel API: https://tu-dominio.vercel.app/api/model-router
# MODEL_ROUTER_URL=http://localhost:3000/api/model-router
# MODEL_ROUTER_TOKEN=router_secret_token
# HUGGINGFACE_API_TOKEN=hf_xxxxx
# ISABELLA_MODEL_NAME=Qwen/Qwen1.5-110B-Chat
# REALITO_MODEL_NAME=Qwen/Qwen1.5-72B-Chat
# OPENLLM_API_URL=https://your-openllm-host
# OPENLLM_API_TOKEN=ollm_xxxxx
# GOOGLE_TTS_API_KEY=AIza...

# === Isabella Voice Engine / TTS (opcional) ===
# Endpoint para Cloud TTS. Por defecto usa /api/tts-isabella (Vercel).
# Para Supabase Edge Functions: https://xxxxx.supabase.co/functions/v1/tts-isabella
# VITE_TTS_ENDPOINT=/api/tts-isabella

# === Google OAuth (opcional — para auth con Google) ===
VITE_NEXT_PUBLIC_SUPABASE_REDIRECT_URL=https://visitarealdelmonte.online/auth/callback
